    <outline text="comics" title="comics">
<outline type="rss" text="Dresden Codak" title="Dresden Codak" xmlUrl="https://dresdencodak.com/feed/" htmlUrl="https://dresdencodak.com" description="A webcomic by A. Senna Diaz described as a celebration of science, death and human folly — stories blending philosophy, science, technology and psychology, following scientist protagonist Kimiko Ross." />
    </outline>
    <outline text="youtube" title="youtube">
      <outline type="rss" text="Scrap Science" title="Scrap Science" xmlUrl="https://www.youtube.com/feeds/videos.xml?channel_id=UCYLvqqVn7Un9lafEXwSW4mA" htmlUrl="https://www.youtube.com/c/ScrapScience" description="New Zealand DIY electrochemistry channel." />
      <outline type="rss" text="styropyro" title="styropyro" xmlUrl="https://www.youtube.com/feeds/videos.xml?channel_id=UCJYJgj7rzsn0vdR7fkgjuIA" htmlUrl="https://www.youtube.com/user/styropyro" description="Infamous DIY science channel (3M+ subscribers) covering high-voltage and high-energy projects like tesla coils and lasers. Gets the science right despite being optimised for clicks. His video on whether volts or amps kill is required viewing." />
      <outline type="rss" text="Advanced Tinkering" title="Advanced Tinkering" xmlUrl="https://www.youtube.com/feeds/videos.xml?channel_id=UC2M2T4FSz1kSqNhhL-n9R9A" htmlUrl="https://www.youtube.com/@AdvancedTinkering" description="German hobbyist DIY science channel, originally focused on synthesising caesium and other alkali metals, now covering a broad range of projects building on other science YouTubers' work. Large budget from 1M+ subscribers." />
      <outline type="rss" text="Applied Science" title="Applied Science" xmlUrl="https://www.youtube.com/feeds/videos.xml?channel_id=UCivA7_KLKWo43tFcCkFvydw" htmlUrl="https://www.youtube.com/channel/UCivA7_KLKWo43tFcCkFvydw" description="Ben Krasnow's channel covering advanced DIY science and engineering projects, including electron microscopy, X-ray systems, aerogel synthesis, and other high-tech electromechanical and chemistry experiments." />
      <outline type="rss" text="shittykickflips" title="shittykickflips" xmlUrl="https://www.youtube.com/feeds/videos.xml?channel_id=UCCuh83YrtAFyCpgWVPQ_PKw" htmlUrl="https://www.youtube.com/@shittykickflips" description="Indie music and film video essays, punk sensibility." />
      <outline type="rss" text="geoh3x" title="geoh3x" xmlUrl="https://www.youtube.com/feeds/videos.xml?channel_id=UC49OtA0LUUvQAP-igakbSlQ" htmlUrl="https://www.youtube.com/@geoh3x" description="Low poly animations." />
      <outline type="rss" text="mallbat" title="mallbat" xmlUrl="https://www.youtube.com/feeds/videos.xml?channel_id=UC9OFDumeHCcZfzUKZW8F7gw" htmlUrl="https://www.youtube.com/@mallbat" description="Low poly animations." />
      <outline type="rss" text="Camille Cooke" title="Camille Cooke" xmlUrl="https://www.youtube.com/feeds/videos.xml?channel_id=UC-oTbS-PARG-kASUBRoCIUQ" htmlUrl="https://www.youtube.com/channel/UC-oTbS-PARG-kASUBRoCIUQ" description="A Film &amp; Animation channel featuring experimental and creative short films." />
      <outline type="rss" text="Extractions&amp;Ire" title="Extractions&amp;Ire" xmlUrl="https://www.youtube.com/feeds/videos.xml?channel_id=UCvFApMFo_AafXbHRyEJefjA" htmlUrl="https://www.youtube.com/channel/UCvFApMFo_AafXbHRyEJefjA" description="Recent ex-PhD student doing DIY chemistry in a shed in Australia. Endearing to watch him struggle with the same obstacles as a PhD. Covers synthesis projects including cubane, tetrazoles, and air-free chemistry." />
      <outline type="rss" text="KaiserBeamz" title="KaiserBeamz" xmlUrl="https://www.youtube.com/feeds/videos.xml?channel_id=UCcxN_gfAE_43Wj6-UWC16bw" htmlUrl="https://www.youtube.com/channel/UCcxN_gfAE_43Wj6-UWC16bw" description="A video essay channel devoted to in-depth analysis and history of classic anime, primarily from the 1980s and 1990s." />
      <outline type="rss" text="Sheafification of G" title="Sheafification of G" xmlUrl="https://www.youtube.com/feeds/videos.xml?channel_id=UC6_J0wZdqcoRVs0Mck922SQ" htmlUrl="https://www.youtube.com/channel/UC6_J0wZdqcoRVs0Mck922SQ" description="A mathematics channel covering advanced and category-theoretic topics such as limits, sheaves, and other concepts from pure mathematics." />
      <outline type="rss" text="hazel" title="hazel" xmlUrl="https://www.youtube.com/feeds/videos.xml?channel_id=UCjNErCQgCndSOl6t33m1-nQ" htmlUrl="https://www.youtube.com/channel/UCjNErCQgCndSOl6t33m1-nQ" description="A video essay channel exploring anime, manga, video games, and internet/fandom history, with a focus on niche and overlooked media from the 1990s and 2000s." />
      <outline type="rss" text="Projects in Flight" title="Projects in Flight" xmlUrl="https://www.youtube.com/feeds/videos.xml?channel_id=UCkyHL2ZPgw9D4GOcPQq6Uzw" htmlUrl="https://www.youtube.com/@projectsinflight" description="Hobbyist electron microscopy and related projects." />
      <outline type="rss" text="Huygens Optics" title="Huygens Optics" xmlUrl="https://www.youtube.com/feeds/videos.xml?channel_id=UC26YLK0OEbLB3TCYxGh8xVQ" htmlUrl="https://www.youtube.com/@HuygensOptics" description="Practical videos on physical optics phenomena, including interferometry, diffraction, and other hands-on optical experiments." />
